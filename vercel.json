{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "installCommand": "corepack enable && corepack prepare pnpm@10.33.0 --activate && pnpm install --frozen-lockfile",
  "buildCommand": "pnpm run build:vercel",
  "outputDirectory": "artifacts/primeaxis/dist/public",
  "framework": null,
  "rewrites": [
    { "source": "/api/((?!healthz$).*)", "destination": "/api" },
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/index.mjs": {
      "maxDuration": 60,
      "includeFiles": "artifacts/api-server/dist/*.mjs"
    },
    "api/healthz.mjs": {
      "maxDuration": 10
    }
  }
}
