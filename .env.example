# =============================================================================
# PrimeAxis Tech — Environment Variables (safe template, no real secrets)
# =============================================================================
#
# Setup:
#   1. Copy:  cp .env.example .env   (Windows: copy .env.example .env)
#   2. Fill in every CHANGE_ME value in .env
#   3. Never put real secrets in this file — .env is gitignored
#
# Run services (Windows PowerShell):
#   pnpm install
#   pnpm dev:api          # API on http://localhost:5000
#   pnpm dev:site         # Frontend on http://localhost:5173
#   pnpm dev:studio       # Sanity Studio on http://localhost:3333
#
# =============================================================================

# --- API server ---
PORT=5000
NODE_ENV=development
LOG_LEVEL=info

# --- Frontend ---
BASE_PATH=/
API_PROXY_TARGET=http://localhost:5000

# --- PostgreSQL ---
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/primeaxis

# --- Sanity CMS ---
SANITY_PROJECT_ID=jyppkgsk
SANITY_DATASET=production
SANITY_API_TOKEN=CHANGE_ME

# --- Cloudinary ---
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# --- Anthropic (content scripts) ---
AI_INTEGRATIONS_ANTHROPIC_API_KEY=CHANGE_ME
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- WaveSpeed (image scripts) ---
WAVESPEED_API_KEY=CHANGE_ME

# --- Imgix / iMix Management API ---
# The user-facing name was "imix"; the documented service for ak_* API keys is likely Imgix.
IMIX_API_KEY=CHANGE_ME
IMGIX_API_KEY=CHANGE_ME
IMGIX_BASE_URL=https://api.imgix.com

# --- ElevenLabs (podcast audio scripts) ---
ELEVENLABS_API_KEY=CHANGE_ME
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
ELEVENLABS_OUTPUT_FORMAT=mp3_44100_128
PODCAST_SITE_URL=https://primeaxis.example.com
PODCAST_FEED_URL=https://primeaxis.example.com/api/podcast/feed.xml
PODCAST_MAX_CHARS=4500

# --- Security ---
SESSION_SECRET=CHANGE_ME_GENERATE_A_RANDOM_SECRET
